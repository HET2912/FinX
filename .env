# =============================================
# FinX Frontend (Vite) - Environment Variables
# =============================================
# All variables MUST be prefixed with VITE_ to be
# exposed to the browser by Vite.
# Never put secrets here — this is client-side code!

# ----- API Base URL --------------------------
# Should point to your backend /api endpoint
# Development:
VITE_API_BASE_URL=https://backend-877g.onrender.com/api/
# Production (uncomment and update when deploying):
# VITE_API_BASE_URL=https://your-backend-domain.com/api
